# Contact form — choose ONE provider (Web3Forms is fastest to set up)

# Option A: Web3Forms (https://web3forms.com — free, no npm package)
# 1. Sign up with info@reshamsutra.com (or any inbox you monitor)
# 2. Create a form and copy the Access Key
WEB3FORMS_ACCESS_KEY=

# Option B: Resend (https://resend.com — needs a verified sending domain)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Resham Sutra <onboarding@resend.dev>
CONTACT_TO_EMAIL=info@reshamsutra.com

# Production site URL (Vercel: set to https://www.reshamsutra.com after domain is connected)
NEXT_PUBLIC_SITE_URL=
